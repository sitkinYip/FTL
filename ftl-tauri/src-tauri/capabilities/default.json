{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "FTL 默认权限",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-file",
    "fs:allow-exists",
    "core:event:allow-listen",
    "core:event:allow-emit"
  ]
}
